---
import Layout from '../layouts/Layout.astro';

const builds = [
  {
    tag: 'PHONE & FRONT-DESK AGENTS',
    title: 'The call gets answered, every time',
    copy: 'A voice agent that picks up, books the appointment straight to your calendar, answers the questions you get asked ten times a day, and routes anything else to the right person on your team.',
  },
  {
    tag: 'INTERNAL AI TOOLS',
    title: 'Automation that survives contact with real use',
    copy: 'Workflow and agent-based tools built for how your business actually runs — not a demo that breaks the first time two people use it at once.',
  },
  {
    tag: 'ARCHITECTURE & SPECS',
    title: 'A design your team can actually build from',
    copy: 'Sometimes the right deliverable isn’t code yet — it’s a clear, buildable design. I’ll architect the system so it’s ready to hand to your team, or to build directly with modern AI coding tools.',
  },
];

const steps = [
  {
    n: '01',
    title: 'Book the assessment',
    copy: 'A focused 1-hour call — $300, paid at booking. We go through what you’re picturing, what’s technically realistic, and what it would take.',
  },
  {
    n: '02',
    title: 'Get a real quote',
    copy: 'Afterward you get a written scope and a fixed quote for the design (and the build, if you want it) — not a vague "let’s see."',
  },
  {
    n: '03',
    title: 'I design it — or build it',
    copy: 'You can take the design to your own team, or I build it myself end to end. Either way, you own what comes out of it.',
  },
];
---
<Layout
  title="Consulting — Rahmi Pruitt"
  description="AI consulting for founders and teams: custom phone agents, internal AI tools, and system design — starting with a $300 paid assessment call."
>
  <section class="wrap con-hero">
    <p class="mono-tag">// ai consultant</p>
    <h1>You bring the idea.<br />I bring the assessment, the quote —<br /><em>and the build, if you want it.</em></h1>
    <p class="con-lede">
      I've spent 7+ years as a software engineer at Amazon Prime Air and Twitch, and I've since
      built and shipped my own production AI products. I translate "we need something like a
      smart phone agent" into a real, working system — without requiring you to know what an
      agent, a webhook, or a queue is.
    </p>
    <a href="#book" class="btn-primary">Book a $300 assessment call &rarr;</a>
  </section>

  <section class="wrap builds-section">
    <p class="mono-tag">// what i build</p>
    <div class="builds-grid">
      {builds.map((b) => (
        <div class="build-card">
          <span class="mono-tag build-tag">{b.tag}</span>
          <h3>{b.title}</h3>
          <p>{b.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="wrap steps-section">
    <p class="mono-tag">// how it works</p>
    <div class="steps-grid">
      {steps.map((s) => (
        <div class="step">
          <span class="step-n">{s.n}</span>
          <h3>{s.title}</h3>
          <p>{s.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="wrap fractional-section">
    <div class="fractional-card">
      <p class="mono-tag">// also available for</p>
      <h2>Fractional &amp; founding engineer work</h2>
      <p>
        Not every engagement is one project. If your team needs someone who can move between
        product, infra, and AI systems without a lot of ramp-up, I take on fractional and founding
        engineer roles alongside consulting work — same call to start the conversation.
      </p>
    </div>
  </section>

  <section class="wrap book-section" id="book">
    <p class="mono-tag">// book the call</p>
    <h2>Assessment call — $300, one hour</h2>
    <p class="book-lede">
      Pick a time below. Payment is collected at booking through Cal.com — no invoices to chase,
      no back-and-forth over email.
    </p>
    <div class="cal-embed" id="cal-embed-placeholder">
      <div class="cal-placeholder">
        <p class="mono-tag">CAL.COM EMBED — pending setup</p>
        <p>
          This slot renders the live Cal.com booking widget once the account and paid event type
          exist. See the setup walkthrough for the exact embed snippet to drop in here.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .con-hero { padding: 64px 0 60px; max-width: 820px; }
  .con-hero h1 {
    font-size: clamp(2rem, 4.2vw, 3rem);
    margin: 14px 0 22px;
  }
  .con-hero h1 em { font-style: italic; color: var(--signal-bright); }
  .con-lede { font-size: 1.08rem; max-width: 62ch; margin-bottom: 28px; }

  .btn-primary {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--signal-bright);
    color: var(--ink);
    padding: 14px 24px;
    border-radius: 3px;
    transition: transform 0.15s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); }

  .builds-section { padding-bottom: 90px; }
  .builds-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 20px;
  }
  .build-card {
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 26px 24px;
    background: var(--ink-raised);
  }
  .build-tag { display: block; margin-bottom: 14px; }
  .build-card h3 { font-size: 1.15rem; margin-bottom: 10px; }
  .build-card p { font-size: 0.92rem; margin: 0; }

  .steps-section { padding-bottom: 90px; }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 24px;
  }
  .step-n {
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--rule);
    display: block;
    margin-bottom: 6px;
  }
  .step h3 { font-size: 1.1rem; margin-bottom: 8px; }
  .step p { font-size: 0.92rem; margin: 0; }

  .fractional-section { padding-bottom: 90px; }
  .fractional-card {
    border: 1px solid var(--moss);
    border-radius: 5px;
    padding: 32px 34px;
    background: linear-gradient(135deg, rgba(60, 82, 64, 0.18), transparent 60%);
  }
  .fractional-card h2 { font-size: 1.6rem; margin: 10px 0 14px; }
  .fractional-card p { max-width: 62ch; margin: 0; }

  .book-section { padding-bottom: 130px; }
  .book-section h2 { font-size: 1.8rem; margin: 10px 0 12px; }
  .book-lede { max-width: 58ch; margin-bottom: 24px; }
  .cal-embed { min-height: 480px; }
  .cal-placeholder {
    border: 1px dashed var(--rule);
    border-radius: 5px;
    padding: 48px 40px;
    text-align: center;
    background: var(--ink-raised);
  }
  .cal-placeholder p:first-child { margin-bottom: 12px; }
  .cal-placeholder p:last-child { max-width: 50ch; margin: 0 auto; color: var(--paper-faint); }

  @media (max-width: 800px) {
    .builds-grid, .steps-grid { grid-template-columns: 1fr; }
  }
</style>
